          <ul class="categoryList" id="categoryList">
            <% for (let category in categories) {%>
              <li class="categoryItem">
                <div class="categoryItem-icon">
                  <span>
                    <% category.icon %>
                  </span>
                </div>
                <p class="categoryItem-text">
                  Anımsatıcılar
                </p>
                <button class="categoryItem-button" id="categoryItem<% ca %>">
                  <i class=" fa-solid fa-map-pin"></i>
                </button>
                <span class="categoryItem-count">3</span>

              </li>
              <% } %>

          </ul>
        </div>
      </div> <!-- Categories -->
      <div class="row my-3">
        <div class="col-12">
          <h6 class="tagList-header">Etiketler</h6>
          <ul class="tagList">
            <li class="tagItem">
              <a href="index?tag=All" class="tagLink"> Tümü </a>
            </li>
            <li class="tagItem">
              <a href="index?tag=Design" class="tagLink"> Tasarım </a>
            </li>
            <li class="tagItem">
